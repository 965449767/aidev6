# Copy this file to keystore.properties and fill in your keystore details.
# Example values are for local debug only.

# Debug signing (also used as fallback for release)
storeFile=keystore/debug.keystore
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME

# Release signing (optional; falls back to debug values if omitted)
# releaseStoreFile=keystore/release.keystore
# releaseStorePassword=CHANGE_ME
# releaseKeyAlias=CHANGE_ME
# releaseKeyPassword=CHANGE_ME
