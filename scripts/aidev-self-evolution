#!/usr/bin/env bash
# aidev-self-evolution —— 自我进化闭环「反向驱动 宇宙A」侧参考实现（Phase G）
#
# 它扮演「宇宙 A（OpenCode）的自动驾驶员」：
#   1) 监听 App 写出的崩溃回流文件：home/workspace/.aidev-loop/crash-<id>.json
#   2) 若 crashed=true 且 fix_applied=false，把崩溃堆栈喂给 OpenCode 让它改码
#   3) OpenCode 改完源码后，写 home/.aidev-build-bridge/req-<id>.json 触发下一轮
#      「宇宙B 编译 → Shizuku 安装 → 自动拉起 → 抓崩溃」
#   4) 把 fix_applied=true + 修复说明回填进崩溃文件，避免重复修同一份
#
# 这是个参考实现：真实环境里也可由 OpenCode 自己定期读该目录并直接改码，
# 不必依赖本脚本。它证明「崩溃 → 改码 → 重建」文件契约是闭合的。
#
# 用法：
#   aidev-self-evolution [--max-iter N] [--once] [--project MyAndroidProject]
#     --once       处理一轮（一个未修复崩溃）后退出
#     --max-iter N 最多自动迭代 N 轮（防失控，默认 5）

set -uo pipefail

MAX_ITER=5
ONCE=0
PROJECT="MyAndroidProject"

while [ $# -gt 0 ]; do
  case "$1" in
    --once) ONCE=1 ;;
    --max-iter) MAX_ITER="${2:-$MAX_ITER}"; shift ;;
    --project) PROJECT="${2:-$PROJECT}"; shift ;;
    *) log "忽略未知参数: $1" ;;
  esac
  shift
done

# 共享工作区（与 App 的 PathConfig.workspaceDir 对应，在宇宙A/宇宙B 中挂载为同一份）
WORKSPACE="${AIDEV_WORKSPACE:-$HOME/workspace}"
LOOP_DIR="$WORKSPACE/.aidev-loop"
BRIDGE_DIR="$HOME/.aidev-build-bridge"

# 找 OpenCode 可执行（按环境调整）
OPENCODE="${OPENCODE_BIN:-opencode}"

log() { echo "[self-evolution $(date +%H:%M:%S)] $*"; }

ensure_dirs() {
  mkdir -p "$LOOP_DIR" "$BRIDGE_DIR"
}

next_crash() {
  # 返回第一个 crashed 且未修复的崩溃文件；没有则空
  for f in "$LOOP_DIR"/crash-*.json; do
    [ -e "$f" ] || continue
    local crashed fix
    crashed=$(grep -o '"crashed"[[:space:]]*:[[:space:]]*\(true\|false\)' "$f" | grep -o 'true' || true)
    fix=$(grep -o '"fix_applied"[[:space:]]*:[[:space:]]*\(true\|false\)' "$f" | grep -o 'true' || true)
    if [ "$crashed" = "true" ] && [ -z "$fix" ]; then
      echo "$f"; return 0
    fi
  done
  return 1
}

mark_fixed() {
  local f="$1" note="$2"
  # 简单回填：把 fix_applied 改为 true，并追加修复说明
  sed -i 's/"fix_applied"[[:space:]]*:[[:space:]]*false/"fix_applied": true/' "$f" 2>/dev/null || true
  printf '\n// fix_note: %s\n' "$note" >> "$f"
}

trigger_rebuild() {
  local id="se-$(date +%s%3N)"
  local req="$BRIDGE_DIR/req-$id.json"
  cat > "$req" <<JSON
{
  "id": "$id",
  "project": "$PROJECT",
  "flavor": "debug",
  "autoInstall": true,
  "autoLaunch": true,
  "triggeredBy": "self-evolution"
}
JSON
  log "已写重建请求 $req（等待宇宙B 编译→安装→拉起→抓崩溃）"
}

drive_one() {
  local f; f=$(next_crash) || { log "没有待修复崩溃，跳过"; return 1; }
  log "发现崩溃回流: $f"
  local pkg stack
  pkg=$(grep -o '"package"[[:space:]]*:[[:space:]]*"[^"]*"' "$f" | head -1 | sed 's/.*:"//;s/"//')
  stack=$(grep -A40 '"stack"' "$f" | sed -n '2,40p')

  if ! command -v "$OPENCODE" >/dev/null 2>&1; then
    log "未找到 $OPENCODE，跳过自动改码。契约文件已就位，可由 OpenCode 手动读取 $f"
    return 1
  fi

  log "把崩溃喂给 $OPENCODE 修复项目 $PROJECT（包 $pkg）…"
  local prompt
  prompt="项目源码在 $WORKSPACE/$PROJECT。下面是一份崩溃回流（已自动安装拉起并抓到）：

$stack

请定位根因并直接修改源码修复它；改完后不要手动构建。改完回复『已修复: <一句话说明>』。"
  local reply
  reply=$("$OPENCODE" --print "$prompt" 2>&1) || { log "OpenCode 调用失败"; return 1; }

  # 回填修复说明并触发下一轮构建
  mark_fixed "$f" "$reply"
  trigger_rebuild
  log "本轮驱动完成，等待下一轮崩溃回流闭合循环。"
  return 0
}

main() {
  ensure_dirs
  local iter=0
  while [ "$iter" -lt "$MAX_ITER" ]; do
    if drive_one; then
      iter=$((iter+1))
    else
      [ "$ONCE" = 1 ] && break
      log "空闲，5s 后重试（Ctrl-C 退出）"
      sleep 5
    fi
    [ "$ONCE" = 1 ] && break
  done
  log "结束（已驱动 $iter 轮）。"
}

main "$@"
